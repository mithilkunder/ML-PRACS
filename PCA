import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA
from sklearn.metrics import confusion_matrix, classification_report
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from mpl_toolkits.mplot3d import Axes3D
import seaborn as sns
df = pd.read_csv("housing.csv")
df = df.fillna(df.mean(numeric_only=True))
df = pd.get_dummies(df, drop_first=True)
X = df.iloc[:, :-1]
y = df.iloc[:, -1]
y = (y > y.median()).astype(int)
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)
cov_matrix = np.cov(X_scaled, rowvar=False)
print("\nCovariance Matrix:\n", cov_matrix)
eigenvalues, eigenvectors = np.linalg.eig(cov_matrix)
sorted_index = np.argsort(eigenvalues)[::-1]
eigenvalues = eigenvalues[sorted_index]
eigenvectors = eigenvectors[:, sorted_index]
print("\nEigenvalues:\n", eigenvalues)
k = 2
top_k_eigenvectors = eigenvectors[:, :k]
X_pca_manual = np.dot(X_scaled, top_k_eigenvectors)
X_reconstructed = np.dot(X_pca_manual, top_k_eigenvectors.T)
plt.figure()
plt.scatter(X_scaled[:, 0], X_scaled[:, 1])
plt.xlabel("Feature 1")
plt.ylabel("Feature 2")
plt.title("Before PCA")
plt.show()
pca_2d = PCA(n_components=2)
X_pca_2d = pca_2d.fit_transform(X_scaled)
plt.figure()
plt.scatter(X_pca_2d[:, 0], X_pca_2d[:, 1])
plt.xlabel("PC1")
plt.ylabel("PC2")
plt.title("After PCA (2D)")
plt.show()
pca_3d = PCA(n_components=3)
X_pca_3d = pca_3d.fit_transform(X_scaled)
fig = plt.figure()
ax = fig.add_subplot(111, projection='3d')
ax.scatter(X_pca_3d[:, 0], X_pca_3d[:, 1], X_pca_3d[:, 2])
ax.set_xlabel("PC1")
ax.set_ylabel("PC2")
ax.set_zlabel("PC3")
ax.set_title("3D PCA Visualization")
plt.show()
pca_full = PCA()
pca_full.fit(X_scaled)
plt.figure()
plt.plot(np.cumsum(pca_full.explained_variance_ratio_))
plt.xlabel("Number of Components")
plt.ylabel("Cumulative Variance")
plt.title("Variance Explained by PCA")
plt.show()
X_train, X_test, y_train, y_test = train_test_split(X_pca_2d, y, test_size=0.2,
random_state=42)
model = LogisticRegression()
model.fit(X_train, y_train)
y_pred = model.predict(X_test)
cm = confusion_matrix(y_test, y_pred)
print("\nConfusion Matrix:\n", cm)
print("\nClassification Report:\n", classification_report(y_test, y_pred))
plt.figure(figsize=(6,5))
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues')
plt.xlabel("Predicted")
plt.ylabel("Actual")
plt.title("Confusion Matrix")
plt.show()
